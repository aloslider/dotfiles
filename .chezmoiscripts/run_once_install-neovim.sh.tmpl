#!/bin/sh
{{ if eq .chezmoi.osRelease.id "nixos" }}
exit 0
{{ end }}

set -euo pipefail

echo "Installing Neovim..."

SRC_DIR="${HOME}/apps/neovim"
BIN_DIR="${HOME}/.local"
BIN_PATH="${BIN_DIR}/bin/nvim"
BUILD_TYPE="RelWithDebInfo"
BRANCH="master"

if [[ -x "${BIN_PATH}" ]]; then
  echo "Neovim already installed at ${BIN_PATH}"
  exit 0
fi

echo "Installing neovim from source"
echo "Target folder: ${SRC_DIR}"
echo "Branch: ${BRANCH}"
echo "Build type: ${BUILD_TYPE}"

{{ if or (eq .chezmoi.osRelease.id "arch") (eq .chezmoi.osRelease.id "cachyos") }}
sudo pacman -S --noconfirm --needed base-devel cmake ninja curl git
{{ end }}

mkdir -p "${HOME}/apps"

if [[ -d "${SRC_DIR}/src" ]]; then
  cd "${SRC_DIR}/src"
  git fetch --all --prune
  git checkout "${BRANCH}"
  git pull
else
  git clone https://github.com/neovim/neovim.git "${SRC_DIR}/src"
  cd "${SRC_DIR}/src"
  git checkout "${BRANCH}"
fi

cd "${SRC_DIR}/src"
rm -rf ${SRC_DIR}/build
make CMAKE_EXTRA_FLAGS="-DCMAKE_INSTALL_PREFIX=${BIN_DIR} -DMIN_LOG_LEVEL=1" CMAKE_BUILD_TYPE=${BUILD_TYPE}
make install
